{
  "name": "@pinecone-database/pinecone",
  "version": "8.0.0",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/pinecone-io/pinecone-ts-client"
  },
  "contributors": [
    "Jen Hamon (https://github.com/jhamon)",
    "Roie Schwaber-Cohen (https://github.com/rschwabco)",
    "Austin DeNoble (https://github.com/austin-denoble)",
    "Audrey Lorberfeld (https://github.com/aulorbe)"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "prepare": "npm run build",
    "build": "rm -rf dist/ && tsc",
    "version": "jq --null-input --arg version $npm_package_version '{\"name\": \"@pinecone-database/pinecone\", \"version\": $version}' > src/version.json",
    "docs:build": "typedoc --plugin ./assets/docs-theme.mjs",
    "generate:openapi": "./codegen/build-oas.sh 2026-04 && npm run build && npm run format",
    "generate:openapi:alpha": "./codegen/build-oas-alpha.sh && npm run build && npm run format",
    "format": "prettier --write .",
    "lint": "eslint src/",
    "repl": "npm run build && tsx scripts/replInit.ts",
    "integration:setup": "npx ts-node ./src/integration/setup.ts",
    "integration:teardown": "npx ts-node ./src/integration/teardown.ts",
    "test:integration:node": "TEST_ENV=node jest src/integration/ -c jest.config.integration-node.js --detectOpenHandles --runInBand --bail --forceExit",
    "test:integration:edge": "TEST_ENV=edge jest src/integration/ -c jest.config.integration-edge.js --detectOpenHandles --runInBand --bail --forceExit",
    "test:integration:local": "./scripts/run-integration-tests-local.sh",
    "test:integration:local:edge": "./scripts/run-integration-tests-local.sh edge",
    "test:integration:cleanup": "npm run build && tsx scripts/cleanupResources.ts",
    "test:external-app-local": "chmod +x ts-external-app-test/local-external-app.sh && ts-external-app-test/local-external-app.sh",
    "test:unit": "jest src/",
    "test:smoke:mocked": "jest -c jest.config.smoke.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@edge-runtime/jest-environment": "^4.0.0",
    "@edge-runtime/types": "^4.0.0",
    "@eslint/js": "^10.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "globals": "^16.0.0",
    "jest": "30.4",
    "jest-progress-bar-reporter": "^1.0.25",
    "prettier": "^3.4.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.23.1",
    "typedoc": "^0.28.20",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.65.0"
  },
  "overrides": {
    "@edge-runtime/jest-environment": {
      "@jest/environment": "^30.0.0",
      "@jest/fake-timers": "^30.0.0",
      "jest-mock": "^30.0.0",
      "jest-util": "^30.0.0"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "/dist"
  ]
}
